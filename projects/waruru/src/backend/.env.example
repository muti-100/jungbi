# OSRM
OSRM_URL=http://localhost:5000

# BLE / Arrival
BLE_RSSI_THRESHOLD=-75
ARRIVAL_REDIS_TTL_SECONDS=300
GPS_FALLBACK_MAX_DISTANCE_METERS=100

# GrowthBook
GROWTHBOOK_API_HOST=http://localhost:3300
GROWTHBOOK_CLIENT_KEY=sdk-xxxx
