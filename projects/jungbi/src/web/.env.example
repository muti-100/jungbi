# ─────────────────────────────────────────────────────────────
# Supabase (required)
# ─────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service role key — server-side only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ─────────────────────────────────────────────────────────────
# Authentication (required)
# ─────────────────────────────────────────────────────────────
# Random 32+ char secret for NextAuth/JWT signing
NEXTAUTH_SECRET=<generate-with-openssl-rand-base64-32>
NEXTAUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Kakao OAuth (optional — for social login)
# ─────────────────────────────────────────────────────────────
# Register at: https://developers.kakao.com
KAKAO_CLIENT_ID=<your-kakao-rest-api-key>
KAKAO_CLIENT_SECRET=<your-kakao-client-secret>

# ─────────────────────────────────────────────────────────────
# Email (optional — for notifications/alerts)
# ─────────────────────────────────────────────────────────────
# Resend API: https://resend.com
RESEND_API_KEY=re_<your-resend-api-key>
EMAIL_FROM=no-reply@jungbinara.kr

# ─────────────────────────────────────────────────────────────
# Payments (optional — Toss Payments)
# ─────────────────────────────────────────────────────────────
# Register at: https://developers.tosspayments.com
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_<your-client-key>
TOSS_SECRET_KEY=test_sk_<your-secret-key>

# ─────────────────────────────────────────────────────────────
# App (optional)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# 공공데이터포털 (data.go.kr)
# ─────────────────────────────────────────────────────────────
# Register at: https://www.data.go.kr
DATA_GO_KR_API_KEY=<your-api-key>

# ─────────────────────────────────────────────────────────────
# Naver Search API (뉴스 검색)
# ─────────────────────────────────────────────────────────────
# Register at: https://developers.naver.com
NAVER_CLIENT_ID=<your-client-id>
NAVER_CLIENT_SECRET=<your-client-secret>
